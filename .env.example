BOT_TOKEN=
ADMIN_ID=
ADMIN_CHAT_ID=

# Downloader service (defaults to cobalt.ollayor.uz if not set)
# For the public cobalt API, use: https://api.cobalt.tools/
# For a self-hosted cobalt (e.g. docker), use e.g.: http://cobalt-api:9000/
API_ENDPOINT=
# API key for the public cobalt API (https://api.cobalt.tools/).
# Get one from https://cobalt.tools/ → Account → API key.
# Leave empty for self-hosted cobalt instances that don't require auth.
COBALT_API_KEY=

# Database file path (inside container use a volume)
DB_PATH=./db.sqlite3

# Cron backup interval in hours (cron.ts)
CRON_INTERVAL_HOURS=5

# Timeout for downloader request in ms
DOWNLOADER_TIMEOUT_MS=20000

# Timeout for document fallback download in ms
DOCUMENT_DOWNLOAD_TIMEOUT_MS=45000

# Optional: channel username or id used in bot.ts
TELEGRAM_CHANNEL_ID=

# ----- Rate limiting (per-user, sliding window in SQLite) -----
# Set to "1" to disable all rate limiting (e.g., during local testing).
RATE_LIMIT_DISABLED=
# Per-user limits per minute, per op bucket.
RATE_LIMIT_DOWNLOAD_PER_MIN=5
RATE_LIMIT_INLINE_PER_MIN=10
RATE_LIMIT_PHOTO_PER_MIN=3
RATE_LIMIT_VIDEO_PER_MIN=3
# How often the rate_events table is pruned of old rows.
RATE_LIMIT_CLEANUP_INTERVAL_MS=60000

# ----- Proxy health checker -----
# Proxy usage is opt-in. Set USE_PROXIES=true to route downloader requests through
# proxies loaded from PROXY_LIST or proxies.json. When unset (default), the bot
# always calls the API directly — safer for local dev pointing at a public endpoint
# where stale proxy lists would otherwise cause silent ECONNRESET failures.
USE_PROXIES=
# URL the checker pings through each proxy. Empty = TCP-connect only.
PROXY_HEALTHCHECK_PROBE_URL=
PROXY_HEALTHCHECK_INTERVAL_MS=60000
PROXY_HEALTHCHECK_TIMEOUT_MS=3000
PROXY_HEALTHCHECK_CONCURRENCY=10

# ----- Circuit breaker (Cobalt API) -----
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_OPEN_DURATION_MS=30000

# ----- Graceful shutdown -----
# Max time the bot will wait for in-flight updates to drain on SIGTERM.
SHUTDRAIN_TIMEOUT_MS=30000
